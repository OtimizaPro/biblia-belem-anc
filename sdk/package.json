{
  "name": "biblia-belem-sdk",
  "version": "0.1.0",
  "description": "SDK JavaScript/TypeScript para a API da Bíblia Belém An.C 2025",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "biblia",
    "bible",
    "belem",
    "api",
    "sdk",
    "interlinear",
    "hebrew",
    "greek",
    "literal-translation"
  ],
  "author": "Belem Anderson Costa",
  "license": "CC-BY-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/OtimizaPro/biblia-belem-anc",
    "directory": "sdk"
  },
  "homepage": "https://biblia.aculpaedasovelhas.org/docs",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
